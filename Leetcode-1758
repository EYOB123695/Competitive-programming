class Solution:
    def minOperations(self, s: str) -> int:
        ans = 0 
        cur = False
        val = s[0]
        for i in range(len(s)):
            if i % 2 != 0 :
                if s[i] != "1":
                    ans +=1 
            else:
                if s[i] != "0":
                    ans += 1 

           
        return min(ans,len(s) - ans) 

        
